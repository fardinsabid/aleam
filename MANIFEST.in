# Core package files
include README.md
include LICENSE
include requirements.txt
include pyproject.toml
include setup.py

# Include all Aleam source files
recursive-include aleam *.py
recursive-include aleam *.pyi
recursive-include aleam *.pyx
recursive-include aleam *.pxd

# Include type hints
include aleam/py.typed

# Exclude all compiled files
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude *.so
global-exclude *.dll
global-exclude *.dylib
global-exclude *.o
global-exclude *.a

# Exclude temporary and cache files
global-exclude *.log
global-exclude *.tmp
global-exclude *.swp
global-exclude *.swo
global-exclude *~
global-exclude .DS_Store
global-exclude Thumbs.db
global-exclude .coverage
global-exclude .pytest_cache
global-exclude .mypy_cache
global-exclude .ruff_cache
global-exclude .benchmarks
global-exclude .tox
global-exclude .nox

# Exclude development directories (not for PyPI)
prune tests
prune benchmarks
prune examples
prune docs
prune .github
prune .vscode
prune .idea
prune .git
prune build
prune dist
prune *.egg-info
prune ai-env
prune venv
prune env
prune .venv
prune .env
prune data
prune outputs
prune logs
prune htmlcov
prune site
prune .ipynb_checkpoints
prune notebooks
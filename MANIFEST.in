# Include core package files
include README.md
include LICENSE
include requirements.txt
include pyproject.toml
include setup.py
include MANIFEST.in

# Include documentation
recursive-include docs *.md
recursive-include docs *.rst
recursive-include docs *.html
include ALEAM_RESEARCH_PAPER.md

# Include examples (optional for distribution)
recursive-include examples *.py
recursive-include examples *.md

# Include test files (for source distribution)
recursive-include tests *.py
recursive-include tests *.txt

# Include benchmark files
recursive-include benchmarks *.py

# Include all Python source files
recursive-include aleam *.py
recursive-include aleam *.pyi
recursive-include aleam *.pxd
recursive-include aleam *.pyx

# Include package data
include aleam/py.typed
recursive-include aleam *.txt
recursive-include aleam *.json
recursive-include aleam *.yaml

# Include configuration files
include .gitignore
include .pre-commit-config.yaml
include .coveragerc
include .flake8
include .mypy.ini

# Include GitHub workflows (optional for source)
recursive-include .github *.yml
recursive-include .github *.yaml

# Exclude unnecessary files from distribution
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude *.so
global-exclude *.dll
global-exclude *.dylib
global-exclude *.o
global-exclude *.a
global-exclude *.log
global-exclude *.tmp
global-exclude *.swp
global-exclude *.swo
global-exclude *~
global-exclude .DS_Store
global-exclude Thumbs.db
global-exclude .coverage
global-exclude coverage.xml
global-exclude .pytest_cache
global-exclude .mypy_cache
global-exclude .ruff_cache
global-exclude .benchmarks

# Exclude virtual environments
prune ai-env
prune venv
prune env
prune .venv
prune .env

# Exclude build artifacts
prune build
prune dist
prune *.egg-info

# Exclude documentation build
prune docs/_build
prune site

# Exclude data directories (if any)
prune data
prune outputs
prune logs

# Exclude IDE files
prune .vscode
prune .idea
prune .pycharm_helpers

# Exclude OS specific files
prune .github
!include .github/workflows/*.yml
prune .git

# Exclude notebooks
prune .ipynb_checkpoints
prune notebooks

# Exclude test artifacts
prune .tox
prune .nox
prune htmlcov

# Include only what's necessary for the package
graft aleam
graft docs
include README.md
include LICENSE
include requirements.txt
include pyproject.toml
include setup.py
# .gitignore — aleam
# Python C++ extension library with CUDA support
# Tracks: source (.cpp .h .cu .py), config, cmake/, scripts/, tests/, examples/
# Ignores: all build artifacts, binaries, caches, envs, IDE files

# ==============================================================================
# Python — compiled & cache
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ==============================================================================
# Python — packaging & distribution
# ==============================================================================
build/
dist/
*.egg-info/
*.egg
.eggs/
MANIFEST
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt
wheels/
share/python-wheels/
.installed.cfg

# Auto-generated version file (written by setuptools-scm or similar)
aleam/_version.py

# ==============================================================================
# Python — compiled C extension (the built .so/.pyd/.dylib)
# These are build outputs — never commit the binary, only the source
# ==============================================================================
aleam/_c_core*.so
aleam/_c_core*.pyd
aleam/_c_core*.dylib
*.so
*.pyd
*.dylib

# ==============================================================================
# C++ — build artifacts
# ==============================================================================
*.o
*.obj
*.a
*.lib
*.exe
*.out
*.app
*.gch
*.pch

# ==============================================================================
# CMake — build artifacts only
# NOTE: cmake/*.cmake source files ARE tracked (AleamConfig, FindPybind11, FindCUDA)
# ==============================================================================
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
_skbuild/
ninja.build
compile_commands.json

# ==============================================================================
# CUDA — compiled artifacts
# NOTE: *.cu and *.cuh source files ARE tracked
# ==============================================================================
*.ptx
*.cubin
*.fatbin

# ==============================================================================
# Virtual environments
# ==============================================================================
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.envrc
.python-version

# ==============================================================================
# Testing & coverage
# ==============================================================================
htmlcov/
.coverage
.coverage.*
.cache
.tox/
.nox/
.hypothesis/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
test-reports/

# ==============================================================================
# Type checking
# ==============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ==============================================================================
# Linting & formatting caches
# ==============================================================================
.ruff_cache/

# ==============================================================================
# IDE & editors
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ==============================================================================
# Jupyter
# ==============================================================================
.ipynb_checkpoints/
*.ipynb

# ==============================================================================
# OS generated
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*.bak
*.tmp

# ==============================================================================
# Logs
# ==============================================================================
*.log
logs/

# ==============================================================================
# Benchmark results (generated data, not source)
# ==============================================================================
.benchmarks/
benchmark.json
asv/
*.bench

# ==============================================================================
# Documentation build output
# ==============================================================================
docs/_build/
site/

# ==============================================================================
# Profiling
# ==============================================================================
*.prof
*.lprof
*.perf

# ==============================================================================
# ML model files (too large for git)
# ==============================================================================
*.pt
*.pth
*.bin
*.gguf
*.safetensors
*.wav
*.mp3

# ==============================================================================
# Data & output directories
# ==============================================================================
data/
outputs/

# ==============================================================================
# Secret / credential files
# ==============================================================================
*.key
*.pem
*.crt
.env
*.local
config.local.py

# ==============================================================================
# Archive files
# ==============================================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ==============================================================================
# Core dumps — FIXED: only matches files named 'core' in root directory
# ==============================================================================
/core
/core.[0-9]*

# ==============================================================================
# PyInstaller
# ==============================================================================
*.manifest
*.spec

# ==============================================================================
# GitHub Actions — TRACK all workflow files
# ==============================================================================
# Do NOT ignore .github directory - track everything inside it
!.github/
!.github/workflows/
!.github/workflows/*.yml

# ==============================================================================
# Assets — TRACK all images, ignore only generated subdirectory
# ==============================================================================
assets/generated/
!assets/
!assets/**/
!assets/**/*.png
!assets/**/*.jpg
!assets/**/*.jpeg
!assets/**/*.svg
!assets/**/*.gif

# ==============================================================================
# External libraries / submodules
# ==============================================================================
third_party/
external/
vendor/